font-family = Hack
font-size = 14
font-thicken = true
adjust-cell-height = 12%
theme = fx
window-save-state = always
window-padding-x = 20
window-padding-y = 8
cursor-style = bar
adjust-cursor-thickness = 3
confirm-close-surface = false
macos-titlebar-style = transparent
split-divider-color = #212224
keybind = cmd+z=text:\x1f
keybind = cmd+shift+z=text:\x1e